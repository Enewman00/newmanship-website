---
import BaseLayout from '@/layouts/BaseLayout.astro';
import {
  generateSoftwareApplicationSchema,
  generateFAQPageSchema,
  generateBreadcrumbSchema,
} from '@/utils/seo';

interface Feature {
  title: string;
  description: string;
  icon?: string;
}

interface FAQ {
  question: string;
  answer: string;
}

interface Props {
  // SEO meta
  title: string;
  description: string;
  canonicalUrl: string;
  image?: string;
  // App identity
  name: string;
  tagline: string;
  appDescription: string;
  category: string;
  platforms: string[];
  appStoreUrl?: string;
  playStoreUrl?: string;
  appleAppId?: string;
  // Content
  features: Feature[];
  faqs?: FAQ[];
  // Branding
  colors: { background: string; accent: string };
  // CTA copy overrides
  ctaHeading?: string;
  ctaSubheading?: string;
  ctaButtonText?: string;
}

const {
  title,
  description,
  canonicalUrl,
  image,
  name,
  tagline,
  appDescription,
  category,
  platforms,
  appStoreUrl,
  playStoreUrl,
  appleAppId,
  features,
  faqs,
  colors,
  ctaHeading = `Download ${name}`,
  ctaSubheading,
  ctaButtonText,
} = Astro.props;

const siteUrl = 'https://newmanship.com';

function hexToRgb(hex: string): [number, number, number] {
  return [
    parseInt(hex.slice(1, 3), 16),
    parseInt(hex.slice(3, 5), 16),
    parseInt(hex.slice(5, 7), 16),
  ];
}

function relativeLuminance([r, g, b]: [number, number, number]): number {
  const toLinear = (c: number) => {
    const s = c / 255;
    return s <= 0.03928 ? s / 12.92 : Math.pow((s + 0.055) / 1.055, 2.4);
  };
  return 0.2126 * toLinear(r) + 0.7152 * toLinear(g) + 0.0722 * toLinear(b);
}

const isDark = relativeLuminance(hexToRgb(colors.background)) < 0.179;

const schemas = [
  generateSoftwareApplicationSchema(name, appDescription, category, platforms, appStoreUrl),
  generateBreadcrumbSchema([
    { name: 'Home', url: siteUrl },
    { name, url: canonicalUrl },
  ]),
  ...(faqs?.length ? [generateFAQPageSchema(faqs)] : []),
];
---

<BaseLayout
  title={title}
  description={description}
  image={image}
  canonicalUrl={canonicalUrl}
  appleAppId={appleAppId}
  structuredData={schemas}
>
  <!-- Hero -->
  <section style={`background-color: ${colors.background};`} class="py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p
        class="text-xs font-semibold uppercase tracking-wider mb-4"
        style={`color: ${colors.accent};`}
      >
        {category}
      </p>
      <h1 class={`text-4xl sm:text-5xl font-bold mb-4 ${isDark ? 'text-white' : 'text-brand-ink'}`}>
        {name}
      </h1>
      <p class={`text-xl mb-6 max-w-2xl mx-auto ${isDark ? 'text-white/70' : 'text-brand-ink-muted'}`}>
        {tagline}
      </p>
      <p class={`mb-10 max-w-xl mx-auto ${isDark ? 'text-white/60' : 'text-brand-ink-muted'}`}>
        {appDescription}
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center flex-wrap">
        {appStoreUrl ? (
          <a
            href={appStoreUrl}
            class="inline-flex items-center gap-2 px-6 py-3 bg-black text-white font-semibold rounded-xl hover:bg-gray-900 transition-colors"
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`Download ${name} on the App Store`}
          >
            <svg class="w-5 h-5 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z" />
            </svg>
            App Store
          </a>
        ) : (
          <p class={`text-sm italic ${isDark ? 'text-white/50' : 'text-brand-ink-muted'}`}>
            Coming soon to the App Store
          </p>
        )}
        {playStoreUrl && (
          <a
            href={playStoreUrl}
            class="inline-flex items-center gap-2 px-6 py-3 bg-black text-white font-semibold rounded-xl hover:bg-gray-900 transition-colors"
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`Get ${name} on Google Play`}
          >
            <svg class="w-5 h-5 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M3 20.5v-17c0-.83.94-1.3 1.6-.8l14 8.5c.6.37.6 1.23 0 1.6l-14 8.5c-.66.5-1.6.03-1.6-.8z" />
            </svg>
            Google Play
          </a>
        )}
      </div>
      <slot name="hero-extra" />
    </div>
  </section>

  <!-- App-specific custom section (e.g., How to Play, impact section) -->
  <slot name="custom-section" />

  <!-- Features grid -->
  <section class="py-20 bg-brand-background">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-brand-ink mb-10 text-center">
        Why {name}?
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {features.map((feature) => (
          <div class="p-6 rounded-2xl bg-brand-surface border border-black/5">
            <h3 class="font-bold mb-2" style={`color: ${colors.accent};`}>
              {feature.title}
            </h3>
            <p class="text-brand-ink-muted text-sm leading-relaxed">{feature.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Default slot for additional app-specific sections -->
  <slot />

  <!-- FAQ -->
  {faqs && faqs.length > 0 && (
    <section class="bg-brand-surface py-20">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold text-brand-ink mb-10 text-center">
          Frequently Asked Questions
        </h2>
        <dl class="space-y-4">
          {faqs.map((faq) => (
            <div class="bg-white rounded-xl p-6 shadow-sm">
              <dt class="font-semibold text-brand-ink mb-2">{faq.question}</dt>
              <dd class="text-brand-ink-muted text-sm leading-relaxed">{faq.answer}</dd>
            </div>
          ))}
        </dl>
      </div>
    </section>
  )}

  <!-- Download CTA -->
  <section style={`background-color: ${colors.background};`} class="py-20">
    <div class="max-w-xl mx-auto px-4 text-center">
      <h2 class={`text-2xl font-bold mb-4 ${isDark ? 'text-white' : 'text-brand-ink'}`}>
        {ctaHeading}
      </h2>
      {ctaSubheading && (
        <p class={`mb-8 ${isDark ? 'text-white/70' : 'text-brand-ink-muted'}`}>
          {ctaSubheading}
        </p>
      )}
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center flex-wrap">
        {appStoreUrl ? (
          <a
            href={appStoreUrl}
            class="inline-flex items-center gap-2 px-8 py-3 font-semibold rounded-xl transition-opacity hover:opacity-90"
            style={`background-color: ${colors.accent}; color: ${isDark ? '#000000' : '#ffffff'};`}
            target="_blank"
            rel="noopener noreferrer"
          >
            {ctaButtonText ?? `Get ${name} Free`}
          </a>
        ) : (
          <p class={`text-sm italic ${isDark ? 'text-white/50' : 'text-brand-ink-muted'}`}>
            Coming soon to the App Store
          </p>
        )}
        {playStoreUrl && (
          <a
            href={playStoreUrl}
            class="inline-flex items-center gap-2 px-8 py-3 font-semibold rounded-xl transition-opacity hover:opacity-90"
            style={`background-color: ${colors.accent}; color: ${isDark ? '#000000' : '#ffffff'};`}
            target="_blank"
            rel="noopener noreferrer"
          >
            Get on Google Play
          </a>
        )}
      </div>
    </div>
  </section>
</BaseLayout>
