---
import BaseLayout from '@/layouts/BaseLayout.astro';
import AppStoreBadges from '@/components/marketing/AppStoreBadges.astro';
import FAQSection from '@/components/marketing/FAQSection.astro';
import CTASection from '@/components/marketing/CTASection.astro';
import {
  generateSoftwareApplicationSchema,
  generateBreadcrumbSchema,
} from '@/utils/seo';

interface Feature {
  title: string;
  description: string;
  icon?: string;
}

interface FAQ {
  question: string;
  answer: string;
}

interface Props {
  // SEO meta
  title: string;
  description: string;
  canonicalUrl: string;
  image?: string;
  // App identity
  name: string;
  tagline: string;
  appDescription: string;
  category: string;
  platforms: string[];
  appStoreUrl?: string;
  playStoreUrl?: string;
  webAppUrl?: string;
  appleAppId?: string;
  iconPath?: string;
  // Content
  features: Feature[];
  faqs?: FAQ[];
  // Branding
  colors: { background: string; accent: string };
  // CTA copy overrides
  ctaHeading?: string;
  ctaSubheading?: string;
}

const {
  title,
  description,
  canonicalUrl,
  image,
  name,
  tagline,
  appDescription,
  category,
  platforms,
  appStoreUrl,
  playStoreUrl,
  webAppUrl,
  appleAppId,
  iconPath,
  features,
  faqs,
  colors,
  ctaHeading = `Download ${name}`,
  ctaSubheading,
} = Astro.props;

const siteUrl = 'https://newmanship.com';

function hexToRgb(hex: string): [number, number, number] {
  return [
    parseInt(hex.slice(1, 3), 16),
    parseInt(hex.slice(3, 5), 16),
    parseInt(hex.slice(5, 7), 16),
  ];
}

function relativeLuminance([r, g, b]: [number, number, number]): number {
  const toLinear = (c: number) => {
    const s = c / 255;
    return s <= 0.03928 ? s / 12.92 : Math.pow((s + 0.055) / 1.055, 2.4);
  };
  return 0.2126 * toLinear(r) + 0.7152 * toLinear(g) + 0.0722 * toLinear(b);
}

const isDark = relativeLuminance(hexToRgb(colors.background)) < 0.179;

const schemas = [
  generateSoftwareApplicationSchema(name, appDescription, category, platforms, appStoreUrl),
  generateBreadcrumbSchema([
    { name: 'Home', url: siteUrl },
    { name, url: canonicalUrl },
  ]),
  // FAQPage schema is emitted inline by <FAQSection> to keep it co-located with the content
];
---

<BaseLayout
  title={title}
  description={description}
  image={image}
  canonicalUrl={canonicalUrl}
  appleAppId={appleAppId}
  structuredData={schemas}
>
  <!-- Hero -->
  <section style={`background-color: ${colors.background};`} class="py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      {iconPath && (
        <picture>
          <source srcset={iconPath.replace('.png', '.webp')} type="image/webp" />
          <img
            src={iconPath}
            alt={`${name} app icon`}
            width="128"
            height="128"
            class="mx-auto mb-6 rounded-3xl shadow-lg"
            loading="eager"
            fetchpriority="high"
          />
        </picture>
      )}
      <p
        class="text-xs font-semibold uppercase tracking-wider mb-4"
        style={`color: ${colors.accent};`}
      >
        {category}
      </p>
      <h1 class={`text-4xl sm:text-5xl font-bold mb-4 ${isDark ? 'text-white' : 'text-brand-ink'}`}>
        {name}
      </h1>
      <p class={`text-xl mb-6 max-w-2xl mx-auto ${isDark ? 'text-white/70' : 'text-brand-ink-muted'}`}>
        {tagline}
      </p>
      <p class={`mb-10 max-w-xl mx-auto ${isDark ? 'text-white/60' : 'text-brand-ink-muted'}`}>
        {appDescription}
      </p>
      <div class="flex justify-center">
        <AppStoreBadges
          appName={name}
          appStoreUrl={appStoreUrl}
          playStoreUrl={playStoreUrl}
          webAppUrl={webAppUrl}
          class={isDark ? '' : '[&_a:not(.web-app-badge)]:!bg-brand-ink [&_a:not(.web-app-badge)]:!border-transparent'}
        />
      </div>
      <slot name="hero-extra" />
    </div>
  </section>

  <!-- App-specific custom section (e.g., How to Play, impact section) -->
  <slot name="custom-section" />

  <!-- Features grid -->
  <section class="py-20 bg-brand-bg">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-brand-ink mb-10 text-center">
        Why {name}?
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {features.map((feature, i) => (
          <div class="p-6 rounded-2xl bg-brand-surface border border-black/5 reveal" style={`--reveal-delay: ${i * 80}ms`}>
            <h3 class="font-bold mb-2" style={`color: ${colors.accent};`}>
              {feature.title}
            </h3>
            <p class="text-brand-ink-muted text-sm leading-relaxed">{feature.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Default slot for additional app-specific sections -->
  <slot />

  <!-- FAQ -->
  {faqs && faqs.length > 0 && (
    <FAQSection faqs={faqs} />
  )}

  <!-- Download CTA -->
  <CTASection
    appName={name}
    appStoreUrl={appStoreUrl}
    playStoreUrl={playStoreUrl}
    webAppUrl={webAppUrl}
    colors={colors}
    isDark={isDark}
    heading={ctaHeading}
    subheading={ctaSubheading}
  />
</BaseLayout>
