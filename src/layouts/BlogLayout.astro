---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TableOfContents from '@/components/blog/TableOfContents.astro';
import BlogCard from '@/components/blog/BlogCard.astro';
import { generateArticleSchema, generateBreadcrumbSchema } from '@/utils/seo';
import type { CollectionEntry } from 'astro:content';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description: string;
  author: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: string;
  tags: string[];
  canonicalUrl: string;
  readingTime: number;
  headings?: Heading[];
  prevPost?: { title: string; slug: string } | null;
  nextPost?: { title: string; slug: string } | null;
  relatedPosts?: CollectionEntry<'blog'>[];
}

const {
  title,
  description,
  author,
  pubDate,
  updatedDate,
  heroImage,
  tags,
  canonicalUrl,
  readingTime,
  headings = [],
  prevPost,
  nextPost,
  relatedPosts = [],
} = Astro.props;

const siteUrl = 'https://newmanship.com';

const articleSchema = generateArticleSchema(
  title,
  description,
  author,
  pubDate,
  updatedDate,
  heroImage ? `${siteUrl}${heroImage}` : undefined,
  canonicalUrl,
);

const breadcrumbSchema = generateBreadcrumbSchema([
  { name: 'Home', url: siteUrl },
  { name: 'Blog', url: `${siteUrl}/blog/` },
  { name: title, url: canonicalUrl },
]);
---

<BaseLayout
  title={`${title} — Newmanship Blog`}
  description={description}
  image={heroImage}
  canonicalUrl={canonicalUrl}
  ogType="article"
  structuredData={[articleSchema, breadcrumbSchema]}
>
  <article class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <nav aria-label="Breadcrumb" class="mb-8">
      <ol class="flex items-center gap-2 text-sm text-brand-ink-muted list-none m-0 p-0">
        <li><a href="/" class="hover:text-brand-accent transition-colors">Home</a></li>
        <li aria-hidden="true">/</li>
        <li><a href="/blog/" class="hover:text-brand-accent transition-colors">Blog</a></li>
        <li aria-hidden="true">/</li>
        <li class="text-brand-ink truncate">{title}</li>
      </ol>
    </nav>

    <header class="mb-10">
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-4">
          {tags.map((tag) => (
            <a
              href={`/blog/?tag=${encodeURIComponent(tag)}`}
              class="text-xs font-semibold uppercase tracking-wider text-brand-accent bg-blue-50 dark:bg-blue-900/20 px-2 py-1 rounded hover:bg-blue-100 dark:hover:bg-blue-900/30 transition-colors"
            >
              {tag}
            </a>
          ))}
        </div>
      )}
      <h1 class="text-3xl sm:text-4xl font-bold text-brand-ink mb-4 leading-tight">
        {title}
      </h1>
      <p class="text-brand-ink-muted text-lg mb-4">{description}</p>
      <div class="flex flex-wrap items-center gap-3 text-sm text-brand-ink-muted">
        <span>{author}</span>
        <span aria-hidden="true">·</span>
        <time datetime={pubDate.toISOString()}>
          {pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        {updatedDate && (
          <>
            <span aria-hidden="true">·</span>
            <span>
              Updated <time datetime={updatedDate.toISOString()}>
                {updatedDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
            </span>
          </>
        )}
        <span aria-hidden="true">·</span>
        <span>{readingTime} min read</span>
      </div>
    </header>

    <TableOfContents headings={headings} />

    <div class="prose prose-lg dark:prose-invert max-w-none prose-headings:font-bold prose-headings:text-brand-ink dark:prose-headings:text-[#F4F1EC] prose-a:text-brand-accent prose-a:no-underline hover:prose-a:underline prose-code:font-mono prose-img:rounded-xl">
      <slot />
    </div>

    {relatedPosts.length > 0 && (
      <aside aria-label="Related posts" class="mt-16 pt-8 border-t border-brand-surface">
        <h2 class="text-xl font-bold text-brand-ink mb-6">Related Posts</h2>
        <ul class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 list-none m-0 p-0">
          {relatedPosts.map((related) => (
            <li>
              <BlogCard post={related} />
            </li>
          ))}
        </ul>
      </aside>
    )}

    {(prevPost || nextPost) && (
      <nav aria-label="Post navigation" class="mt-16 pt-8 border-t border-brand-surface">
        <div class="flex flex-col sm:flex-row gap-4">
          {prevPost ? (
            <a
              href={`/blog/${prevPost.slug}/`}
              class="group flex flex-col gap-1 p-4 rounded-xl bg-brand-surface dark:bg-[#1C1C1F] hover:bg-[#E8E4DC] dark:hover:bg-[#252528] transition-colors min-w-0 flex-1"
            >
              <span class="text-xs font-semibold uppercase tracking-wider text-brand-ink-muted">← Previous</span>
              <span class="text-brand-ink font-medium group-hover:text-brand-accent transition-colors line-clamp-2">{prevPost.title}</span>
            </a>
          ) : <div class="flex-1" />}
          {nextPost ? (
            <a
              href={`/blog/${nextPost.slug}/`}
              class="group flex flex-col gap-1 p-4 rounded-xl bg-brand-surface hover:bg-[#E8E4DC] transition-colors min-w-0 flex-1 sm:items-end sm:text-right"
            >
              <span class="text-xs font-semibold uppercase tracking-wider text-brand-ink-muted">Next →</span>
              <span class="text-brand-ink font-medium group-hover:text-brand-accent transition-colors line-clamp-2">{nextPost.title}</span>
            </a>
          ) : <div class="flex-1" />}
        </div>
      </nav>
    )}
  </article>
</BaseLayout>
