---
import AppLandingLayout from '@/layouts/AppLandingLayout.astro';
import { getEntry } from 'astro:content';

const app = await getEntry('apps', 'stellar-habits');
const { name, tagline, description, category, platforms, appStoreUrl, playStoreUrl, features, faqs, colors } = app.data;

const pageUrl = 'https://newmanship.com/stellar-habits/';
---

<AppLandingLayout
  title="Stellar Habits — Beautiful Habit Tracker for iOS"
  description="A habit tracker that replaces checkboxes with an interactive night sky. Hold your habits to watch them glow. No streaks, no pressure — just beautiful consistency."
  canonicalUrl={pageUrl}
  name={name}
  tagline={tagline}
  appDescription={description}
  category={category}
  platforms={platforms}
  appStoreUrl={appStoreUrl}
  playStoreUrl={playStoreUrl}
  features={features}
  faqs={faqs}
  colors={colors}
  ctaHeading="Start building beautiful habits."
  ctaSubheading="No streaks. No anxiety. Just you and your stars."
  ctaButtonText="Get Stellar Habits"
/>
