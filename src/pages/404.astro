---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found - Newmanship"
  description="The page you're looking for doesn't exist. Head back to Newmanship to explore our apps."
>
  <section class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-32 text-center">
    <p class="text-8xl font-bold text-brand-accent mb-6" aria-hidden="true">404</p>
    <h1 class="text-3xl font-bold text-brand-ink mb-4">Page not found</h1>
    <p class="text-brand-ink-muted text-lg mb-10">
      The page you're looking for doesn't exist or may have been moved.
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center mb-16">
      <a
        href="/"
        class="inline-flex items-center justify-center gap-2 bg-brand-accent hover:bg-brand-accent-hover text-white font-semibold px-6 py-3 rounded-lg transition-colors"
      >
        Go home
      </a>
      <a
        href="/blog/"
        class="inline-flex items-center justify-center gap-2 border border-brand-surface bg-brand-surface hover:border-brand-accent text-brand-ink font-semibold px-6 py-3 rounded-lg transition-colors"
      >
        Read the blog
      </a>
    </div>

    <div class="border-t border-brand-surface pt-10">
      <p class="text-sm text-brand-ink-muted mb-5">Or jump straight to an app:</p>
      <nav aria-label="App pages" class="flex flex-wrap justify-center gap-3">
        <a href="/sumstone/" class="text-sm font-medium text-brand-accent hover:underline">Sumstone</a>
        <span class="text-brand-ink-muted" aria-hidden="true">·</span>
        <a href="/stellar-habits/" class="text-sm font-medium text-brand-accent hover:underline">Stellar Habits</a>
        <span class="text-brand-ink-muted" aria-hidden="true">·</span>
        <a href="/choreganized/" class="text-sm font-medium text-brand-accent hover:underline">Choreganized</a>
        <span class="text-brand-ink-muted" aria-hidden="true">·</span>
        <a href="/sprout-alarm/" class="text-sm font-medium text-brand-accent hover:underline">SproutAwake</a>
      </nav>
    </div>
  </section>
</BaseLayout>
