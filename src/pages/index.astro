---
import BaseLayout from '@/layouts/BaseLayout.astro';
import HeroSection from '@/components/marketing/HeroSection.astro';
import AppCard from '@/components/marketing/AppCard.astro';
import { getCollection } from 'astro:content';
import { generateOrganizationSchema, generateWebSiteSchema } from '@/utils/seo';

const siteUrl = 'https://newmanship.com';
const schemas = [
  generateOrganizationSchema(siteUrl),
  generateWebSiteSchema(siteUrl),
];

const APP_ORDER = ['sumstone', 'stellar-habits', 'choreganized', 'sprout-alarm'];
const allApps = await getCollection('apps');
const apps = APP_ORDER.map((slug) => allApps.find((a) => a.id === slug)!).filter(Boolean);
---

<BaseLayout
  title="Newmanship — Apps That Make Daily Life Better"
  description="Newmanship is an indie app studio crafting thoughtful mobile apps. Discover Sumstone, Stellar Habits, Choreganized, and Sprout Alarm."
  structuredData={schemas}
>
  <HeroSection />

  <section id="apps" class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pb-24">
    <h2 class="text-2xl font-bold text-brand-ink mb-8 text-center">The Apps</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      {apps.map((app) => (
        <AppCard
          name={app.data.name}
          slug={app.data.slug}
          tagline={app.data.tagline}
          category={app.data.category}
          platforms={app.data.platforms}
          colors={app.data.colors}
          iconPath={app.data.iconPath}
        />
      ))}
    </div>
  </section>

  <section class="bg-brand-surface py-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl font-bold text-brand-ink mb-4">About Newmanship</h2>
      <p class="text-brand-ink-muted max-w-2xl mx-auto leading-relaxed">
        Newmanship is a one-person indie app studio focused on craft, simplicity, and privacy.
        Every app is designed to do one thing well — no dark patterns, no data harvesting, no bloat.
        Just tools that make your day a little better.
      </p>
    </div>
  </section>
</BaseLayout>
