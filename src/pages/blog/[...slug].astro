---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { generateArticleSchema, generateBreadcrumbSchema } from '@/utils/seo';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content } = await post.render();

const siteUrl = 'https://newmanship.com';
const postUrl = `${siteUrl}/blog/${post.slug}/`;

const articleSchema = generateArticleSchema(
  post.data.title,
  post.data.description,
  post.data.author,
  post.data.pubDate,
  post.data.updatedDate,
  post.data.heroImage ? `${siteUrl}${post.data.heroImage}` : undefined,
  postUrl,
);

const breadcrumbSchema = generateBreadcrumbSchema([
  { name: 'Home', url: siteUrl },
  { name: 'Blog', url: `${siteUrl}/blog/` },
  { name: post.data.title, url: postUrl },
]);
---

<BaseLayout
  title={`${post.data.title} — Newmanship Blog`}
  description={post.data.description}
  image={post.data.heroImage}
  canonicalUrl={postUrl}
  structuredData={[articleSchema, breadcrumbSchema]}
>
  <article class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <nav aria-label="Breadcrumb" class="mb-8">
      <ol class="flex items-center gap-2 text-sm text-[#6B6B6B] list-none m-0 p-0">
        <li><a href="/" class="hover:text-[#2563EB] transition-colors">Home</a></li>
        <li aria-hidden="true">/</li>
        <li><a href="/blog/" class="hover:text-[#2563EB] transition-colors">Blog</a></li>
        <li aria-hidden="true">/</li>
        <li class="text-[#1A1A1A] truncate">{post.data.title}</li>
      </ol>
    </nav>

    <header class="mb-10">
      {post.data.tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-4">
          {post.data.tags.map((tag) => (
            <span class="text-xs font-semibold uppercase tracking-wider text-[#2563EB] bg-blue-50 px-2 py-1 rounded">
              {tag}
            </span>
          ))}
        </div>
      )}
      <h1 class="text-3xl sm:text-4xl font-bold text-[#1A1A1A] mb-4 leading-tight">
        {post.data.title}
      </h1>
      <p class="text-[#6B6B6B] text-lg mb-4">{post.data.description}</p>
      <div class="flex items-center gap-3 text-sm text-[#6B6B6B]">
        <span>{post.data.author}</span>
        <span aria-hidden="true">·</span>
        <time datetime={post.data.pubDate.toISOString()}>
          {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
      </div>
    </header>

    <div class="prose prose-lg max-w-none prose-headings:font-bold prose-headings:text-[#1A1A1A] prose-a:text-[#2563EB] prose-a:no-underline hover:prose-a:underline">
      <Content />
    </div>
  </article>
</BaseLayout>
