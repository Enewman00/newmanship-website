---
import AppLandingLayout from '@/layouts/AppLandingLayout.astro';
import { getEntry } from 'astro:content';

const app = await getEntry('apps', 'sumstone');
const { name, tagline, description, category, platforms, appStoreUrl, playStoreUrl, features, faqs, colors } = app.data;

const pageUrl = 'https://newmanship.com/sumstone/';
---

<AppLandingLayout
  title="Sumstone — Free Math Puzzle Game | Countdown Numbers"
  description="A calm, satisfying math puzzle inspired by the Countdown numbers round. Six numbers, one target, endless combinations. Free, offline, no ads."
  canonicalUrl={pageUrl}
  name={name}
  tagline={tagline}
  appDescription={description}
  category={category}
  platforms={platforms}
  appStoreUrl={appStoreUrl}
  playStoreUrl={playStoreUrl}
  features={features}
  faqs={faqs}
  colors={colors}
  ctaHeading="Ready to play?"
  ctaSubheading="Free to download. No internet required. No ads."
/>
