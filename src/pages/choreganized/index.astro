---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getEntry } from 'astro:content';
import { generateSoftwareApplicationSchema, generateFAQPageSchema, generateBreadcrumbSchema } from '@/utils/seo';

const app = await getEntry('apps', 'choreganized');
const { name, tagline, description, category, platforms, appStoreUrl, features, faqs } = app.data;

const siteUrl = 'https://newmanship.com';
const pageUrl = `${siteUrl}/choreganized/`;

const schemas = [
  generateSoftwareApplicationSchema(name, description, category, platforms, appStoreUrl),
  generateBreadcrumbSchema([
    { name: 'Home', url: siteUrl },
    { name: name, url: pageUrl },
  ]),
  ...(faqs ? [generateFAQPageSchema(faqs)] : []),
];
---

<BaseLayout
  title="Choreganized — Smart Chore & Reminder Manager"
  description="Stay on top of every chore, reminder, and recurring task. Smart scheduling, clear priorities, and all data stored privately on your device."
  canonicalUrl={pageUrl}
  structuredData={schemas}
>
  <!-- Hero -->
  <section class="bg-[#FBF6EC] py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-xs font-semibold uppercase tracking-wider text-[#6366F1] mb-4">{category}</p>
      <h1 class="text-4xl sm:text-5xl font-bold text-[#1A1A1A] mb-4">{name}</h1>
      <p class="text-xl text-[#6B6B6B] mb-6 max-w-2xl mx-auto">{tagline}</p>
      <p class="text-[#6B6B6B] mb-10 max-w-xl mx-auto">{description}</p>
      {appStoreUrl ? (
        <a href={appStoreUrl} class="inline-block px-8 py-3 bg-[#6366F1] text-white font-semibold rounded-xl hover:bg-[#4F46E5] transition-colors" target="_blank" rel="noopener noreferrer">
          Download on the App Store
        </a>
      ) : (
        <p class="text-sm text-[#6B6B6B] italic">Coming soon to the App Store</p>
      )}
    </div>
  </section>

  <!-- Features -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <h2 class="text-2xl font-bold text-[#1A1A1A] mb-10 text-center">Everything in its place</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      {features.map((feature) => (
        <div class="p-6 rounded-2xl bg-[#FBF6EC] border border-[#EDE8DC]">
          <h3 class="font-bold text-[#1A1A1A] mb-2">{feature.title}</h3>
          <p class="text-[#6B6B6B] text-sm">{feature.description}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- FAQ -->
  {faqs && faqs.length > 0 && (
    <section class="bg-[#F2F0EC] py-20">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold text-[#1A1A1A] mb-10 text-center">Frequently Asked Questions</h2>
        <dl class="space-y-6">
          {faqs.map((faq) => (
            <div class="bg-white rounded-xl p-6">
              <dt class="font-semibold text-[#1A1A1A] mb-2">{faq.question}</dt>
              <dd class="text-[#6B6B6B] text-sm leading-relaxed">{faq.answer}</dd>
            </div>
          ))}
        </dl>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="py-20 text-center">
    <div class="max-w-xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-[#1A1A1A] mb-4">Never miss what matters.</h2>
      <p class="text-[#6B6B6B] mb-8">Private by design. Smart by default.</p>
      {appStoreUrl ? (
        <a href={appStoreUrl} class="inline-block px-8 py-3 bg-[#6366F1] text-white font-semibold rounded-xl hover:bg-[#4F46E5] transition-colors" target="_blank" rel="noopener noreferrer">
          Get Choreganized
        </a>
      ) : (
        <p class="text-sm text-[#6B6B6B] italic">Coming soon to the App Store</p>
      )}
    </div>
  </section>
</BaseLayout>
