---
import AppLandingLayout from '@/layouts/AppLandingLayout.astro';
import { getEntry } from 'astro:content';

const app = await getEntry('apps', 'choreganized');
const { name, tagline, description, category, platforms, appStoreUrl, playStoreUrl, features, faqs, colors } = app.data;

const pageUrl = 'https://newmanship.com/choreganized/';
---

<AppLandingLayout
  title="Choreganized — Smart Chore & Reminder Manager"
  description="Stay on top of every chore, reminder, and recurring task. Smart scheduling, clear priorities, and all data stored privately on your device."
  canonicalUrl={pageUrl}
  name={name}
  tagline={tagline}
  appDescription={description}
  category={category}
  platforms={platforms}
  appStoreUrl={appStoreUrl}
  playStoreUrl={playStoreUrl}
  features={features}
  faqs={faqs}
  colors={colors}
  ctaHeading="Never miss what matters."
  ctaSubheading="Private by design. Smart by default."
  ctaButtonText="Get Choreganized"
/>
