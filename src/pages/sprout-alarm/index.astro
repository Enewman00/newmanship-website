---
import AppLandingLayout from '@/layouts/AppLandingLayout.astro';
import { getEntry } from 'astro:content';

const app = await getEntry('apps', 'sprout-alarm');
const { name, tagline, description, category, platforms, appStoreUrl, playStoreUrl, features, faqs, colors } = app.data;

const pageUrl = 'https://newmanship.com/sprout-alarm/';
---

<AppLandingLayout
  title="Sprout Alarm — Wake Up & Plant Trees"
  description="An alarm app where waking up earns eco points that fund real tree planting. 50% of subscription revenue goes to reforestation. Wake challenges make sure you're actually up."
  canonicalUrl={pageUrl}
  name={name}
  tagline={tagline}
  appDescription={description}
  category={category}
  platforms={platforms}
  appStoreUrl={appStoreUrl}
  playStoreUrl={playStoreUrl}
  features={features}
  faqs={faqs}
  colors={colors}
  ctaHeading="Wake up. Make a difference."
  ctaSubheading="Every morning counts — for you and the planet."
  ctaButtonText="Get Sprout Alarm"
>
  <!-- Impact section specific to Sprout Alarm -->
  <section slot="custom-section" style={`background-color: ${colors.accent};`} class="py-16 text-center">
    <div class="max-w-2xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-white mb-4">50% of every Pro subscription plants trees.</h2>
      <p class="text-white/80">
        We partner with verified reforestation organizations to ensure every dollar goes
        to planting real trees in real forests. Track your personal impact in the app.
      </p>
    </div>
  </section>
</AppLandingLayout>
