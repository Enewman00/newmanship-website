---
interface Props {
  appName: string;
  appStoreUrl?: string;
  playStoreUrl?: string;
  webAppUrl?: string;
  class?: string;
}

const { appName, appStoreUrl, playStoreUrl, webAppUrl, class: className = '' } = Astro.props;
---

<div class:list={['flex flex-col sm:flex-row gap-3 items-center flex-wrap', className]}>
  {webAppUrl && (
    <a
      href={webAppUrl}
      target="_blank"
      rel="noopener noreferrer"
      aria-label={`Play ${appName} in your browser`}
      class="web-app-badge flex items-center gap-3 bg-blue-600 text-white px-5 py-2.5 rounded-xl hover:bg-blue-700 transition-colors h-14 border border-blue-400/20 shadow-md shadow-blue-600/20"
      data-analytics-event="Web App Click"
      data-analytics-app={appName}
      data-analytics-store="Web"
    >
      <svg class="w-7 h-7 shrink-0" viewBox="0 0 24 24" fill="white" aria-hidden="true">
        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z" />
      </svg>
      <div class="leading-tight text-left">
        <div class="text-[10px] uppercase tracking-wider opacity-80">Play now in</div>
        <div class="text-lg font-semibold -mt-0.5">Your Browser</div>
      </div>
    </a>
  )}
  {appStoreUrl ? (
    <a
      href={appStoreUrl}
      target="_blank"
      rel="noopener noreferrer"
      aria-label={`Download ${appName} on the App Store`}
      class="flex items-center gap-3 bg-black text-white px-5 py-2.5 rounded-xl hover:bg-gray-900 transition-colors h-14 border border-white/10"
      data-analytics-event="App Store Click"
      data-analytics-app={appName}
      data-analytics-store="App Store"
    >
      <svg class="w-7 h-7 shrink-0" viewBox="0 0 24 24" fill="white" aria-hidden="true">
        <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z" />
      </svg>
      <div class="leading-tight text-left">
        <div class="text-[10px] uppercase tracking-wider opacity-80">Download on the</div>
        <div class="text-lg font-semibold -mt-0.5">App Store</div>
      </div>
    </a>
  ) : (
    <p class="text-sm italic opacity-60">Coming soon to the App Store</p>
  )}
  {playStoreUrl && (
    <a
      href={playStoreUrl}
      target="_blank"
      rel="noopener noreferrer"
      aria-label={`Get ${appName} on Google Play`}
      class="flex items-center gap-3 bg-black text-white px-5 py-2.5 rounded-xl hover:bg-gray-900 transition-colors h-14 border border-white/10"
      data-analytics-event="App Store Click"
      data-analytics-app={appName}
      data-analytics-store="Google Play"
    >
      <svg class="w-7 h-7 shrink-0" viewBox="0 0 24 24" fill="white" aria-hidden="true">
        <path d="M3 20.5v-17c0-.83.94-1.3 1.6-.8l14 8.5c.6.37.6 1.23 0 1.6l-14 8.5c-.66.5-1.6.03-1.6-.8z" />
      </svg>
      <div class="leading-tight text-left">
        <div class="text-[10px] uppercase tracking-wider opacity-80">Get it on</div>
        <div class="text-lg font-semibold -mt-0.5">Google Play</div>
      </div>
    </a>
  )}
</div>

<script>
  type PlausibleFn = (event: string, opts: { props: Record<string, string> }) => void;

  function bindBadgeTracking() {
    document.querySelectorAll<HTMLAnchorElement>('[data-analytics-event]').forEach((link) => {
      link.addEventListener('click', () => {
        const plausible = (window as unknown as { plausible?: PlausibleFn }).plausible;
        plausible?.(link.dataset.analyticsEvent!, {
          props: {
            app: link.dataset.analyticsApp || '',
            store: link.dataset.analyticsStore || '',
          },
        });
      });
    });
  }

  document.addEventListener('astro:page-load', bindBadgeTracking);
</script>
