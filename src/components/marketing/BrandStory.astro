---
interface Props {
  avatarPath?: string;
}

const { avatarPath } = Astro.props;

const values = [
  {
    label: 'Craft',
    description: 'Every detail is considered — typography, interaction, performance.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/><path d="M18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456z"/></svg>`,
  },
  {
    label: 'Privacy',
    description: 'No accounts required, no data harvesting. Your data stays on your device.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"/></svg>`,
  },
  {
    label: 'Simplicity',
    description: 'One app, one job, done well. No dark patterns, no bloat, no distractions.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/></svg>`,
  },
];
---

<section class="bg-brand-surface py-20">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      {avatarPath && (
        <img
          src={avatarPath}
          alt="Ethan Newman, Newmanship founder"
          width="80"
          height="80"
          class="w-20 h-20 rounded-full mx-auto mb-6 object-cover"
          loading="lazy"
        />
      )}
      <h2 class="text-2xl font-bold text-brand-ink mb-4">About Newmanship</h2>
      <p class="text-lg text-brand-ink-muted max-w-2xl mx-auto leading-relaxed">
        Newmanship is a one-person indie studio building thoughtful mobile apps for iOS and Android.
        Every app does one thing well — no dark patterns, no data harvesting, no bloat.
        Just tools that make your day a little better.
      </p>
    </div>

    <dl class="grid grid-cols-1 sm:grid-cols-3 gap-6">
      {values.map((value) => (
        <div class="flex flex-col items-center text-center gap-3 bg-brand-bg rounded-2xl px-6 py-8 border border-brand-surface shadow-sm">
          <div class="w-10 h-10 text-brand-accent flex-shrink-0" set:html={value.icon} />
          <dt class="font-semibold text-brand-ink">{value.label}</dt>
          <dd class="text-sm text-brand-ink-muted leading-relaxed">{value.description}</dd>
        </div>
      ))}
    </dl>
  </div>
</section>
