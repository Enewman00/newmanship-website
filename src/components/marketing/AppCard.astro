---
interface Props {
  name: string;
  slug: string;
  tagline: string;
  category: string;
  platforms: string[];
  colors: {
    background: string;
    accent: string;
  };
  iconPath?: string;
}

const { name, slug, tagline, category, platforms, colors, iconPath } = Astro.props;

function isDark(hex: string): boolean {
  const r = parseInt(hex.slice(1, 3), 16);
  const g = parseInt(hex.slice(3, 5), 16);
  const b = parseInt(hex.slice(5, 7), 16);
  return (0.299 * r + 0.587 * g + 0.114 * b) / 255 < 0.5;
}

const dark = isDark(colors.background);
const textColor = dark ? '#FFFFFF' : '#1A1A1A';
const mutedColor = dark ? '#9CA3AF' : '#6B6B6B';
const borderColor = dark
  ? `${colors.accent}33`
  : `${colors.accent}40`;
---

<a
  href={`/${slug}/`}
  class="group block p-6 rounded-2xl transition-all duration-200 hover:shadow-lg hover:scale-[1.01] border"
  style={`background-color: ${colors.background}; border-color: transparent;`}
  onmouseenter={`this.style.borderColor='${borderColor}'`}
  onmouseleave={`this.style.borderColor='transparent'`}
>
  {iconPath && (
    <img
      src={iconPath}
      alt={`${name} app icon`}
      width="64"
      height="64"
      class="rounded-2xl mb-4"
      loading="lazy"
    />
  )}

  <div class="flex items-start justify-between gap-2 mb-3">
    <p
      class="text-xs font-semibold uppercase tracking-wider"
      style={`color: ${colors.accent};`}
    >
      {category}
    </p>
    <div class="flex gap-1 shrink-0">
      {platforms.map((p) => (
        <span
          class="text-[10px] font-medium px-1.5 py-0.5 rounded-full border"
          style={`color: ${mutedColor}; border-color: ${mutedColor}40;`}
        >
          {p}
        </span>
      ))}
    </div>
  </div>

  <h3
    class="text-xl font-bold mb-2"
    style={`color: ${textColor};`}
  >
    {name}
  </h3>

  <p
    class="text-sm leading-relaxed mb-5"
    style={`color: ${mutedColor};`}
  >
    {tagline}
  </p>

  <span
    class="inline-flex items-center gap-1.5 text-sm font-semibold transition-gap duration-150 group-hover:gap-2.5"
    style={`color: ${colors.accent};`}
  >
    Learn more
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="15"
      height="15"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M5 12h14M12 5l7 7-7 7"/>
    </svg>
  </span>
</a>
