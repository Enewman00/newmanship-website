---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;

// Only include h2 and h3; skip if fewer than 2 headings
const filtered = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

{filtered.length >= 2 && (
  <nav aria-label="Table of contents" class="not-prose mb-10 p-5 rounded-2xl bg-brand-surface border border-[#E8E4DC]">
    <p class="text-xs font-semibold uppercase tracking-widest text-brand-ink-muted mb-3">On this page</p>
    <ol class="list-none m-0 p-0 space-y-1">
      {filtered.map((heading) => (
        <li class:list={['leading-snug', heading.depth === 3 && 'pl-4']}>
          <a
            href={`#${heading.slug}`}
            class="text-sm text-brand-ink-muted hover:text-brand-accent transition-colors"
          >
            {heading.text}
          </a>
        </li>
      ))}
    </ol>
  </nav>
)}
