---
interface Props {
  tags: string[];
  activeTag?: string;
  class?: string;
}

const { tags, activeTag = '', class: className = '' } = Astro.props;
---

{tags.length > 0 && (
  <ul class={`flex flex-wrap gap-2 list-none m-0 p-0 ${className}`} role="list" aria-label="Post tags">
    {tags.map((tag) => (
      <li>
        <a
          href={`/blog/?tag=${encodeURIComponent(tag)}`}
          class:list={[
            'text-xs font-semibold uppercase tracking-wider px-2.5 py-1 rounded transition-colors',
            activeTag === tag
              ? 'bg-brand-accent text-white'
              : 'bg-blue-50 text-brand-accent hover:bg-blue-100',
          ]}
        >
          {tag}
        </a>
      </li>
    ))}
  </ul>
)}
