---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;

const excerpt =
  post.data.description.length > 160
    ? post.data.description.slice(0, 157) + '...'
    : post.data.description;

const wordCount = post.body.split(/\s+/).filter(Boolean).length;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));
---

<a href={`/blog/${post.slug}/`} class="block group h-full">
  <article class="p-6 rounded-2xl bg-brand-surface hover:shadow-md transition-shadow h-full flex flex-col">
    {post.data.tags.length > 0 && (
      <div class="flex flex-wrap gap-1 mb-3">
        {post.data.tags.slice(0, 2).map((tag) => (
          <span class="text-xs font-semibold uppercase tracking-wider text-brand-accent bg-blue-50 px-2 py-0.5 rounded">
            {tag}
          </span>
        ))}
      </div>
    )}
    <h2 class="text-lg font-bold text-brand-ink mb-2 group-hover:text-brand-accent transition-colors leading-snug">
      {post.data.title}
    </h2>
    <p class="text-brand-ink-muted text-sm mb-4 flex-1 leading-relaxed">{excerpt}</p>
    <div class="flex items-center gap-2 text-xs text-brand-ink-muted mt-auto">
      <time datetime={post.data.pubDate.toISOString()}>
        {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
      </time>
      <span aria-hidden="true">·</span>
      <span>{readingTime} min read</span>
    </div>
  </article>
</a>
