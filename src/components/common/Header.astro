---
const navLinks = [
  { href: '/sumstone/', label: 'Sumstone' },
  { href: '/stellar-habits/', label: 'Stellar Habits' },
  { href: '/choreganized/', label: 'Choreganized' },
  { href: '/sprout-alarm/', label: 'Sprout Alarm' },
  { href: '/blog/', label: 'Blog' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-[#FAFAF8]/95 dark:bg-[#111113]/95 backdrop-blur border-b border-[#F2F0EC] dark:border-[#1C1C1F]">
  <nav class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-16" aria-label="Main navigation">
    <a href="/" class="flex items-center gap-2 font-bold text-lg text-[#1A1A1A] dark:text-[#F4F1EC] hover:text-[#2563EB] dark:hover:text-[#3B82F6] transition-colors">
      <span>Newmanship</span>
    </a>

    <!-- Desktop nav -->
    <ul class="hidden md:flex items-center gap-1 list-none m-0 p-0">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              'px-3 py-2 rounded-md text-sm font-medium transition-colors',
              currentPath.startsWith(href)
                ? 'text-[#2563EB] dark:text-[#3B82F6] bg-blue-50 dark:bg-blue-900/20'
                : 'text-[#6B6B6B] dark:text-[#9B9B9B] hover:text-[#1A1A1A] dark:hover:text-[#F4F1EC] hover:bg-[#F2F0EC] dark:hover:bg-[#1C1C1F]',
            ]}
            aria-current={currentPath.startsWith(href) ? 'page' : undefined}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <div class="flex items-center gap-2">
      <!-- Dark mode toggle -->
      <button
        id="theme-toggle"
        class="p-2 rounded-md text-[#6B6B6B] dark:text-[#9B9B9B] hover:text-[#1A1A1A] dark:hover:text-[#F4F1EC] hover:bg-[#F2F0EC] dark:hover:bg-[#1C1C1F] transition-colors"
        aria-label="Toggle dark mode"
      >
        <!-- Moon icon — visible in light mode -->
        <svg id="theme-icon-moon" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
        </svg>
        <!-- Sun icon — visible in dark mode -->
        <svg id="theme-icon-sun" class="w-5 h-5 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="5" />
          <line x1="12" y1="1" x2="12" y2="3" />
          <line x1="12" y1="21" x2="12" y2="23" />
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
          <line x1="1" y1="12" x2="3" y2="12" />
          <line x1="21" y1="12" x2="23" y2="12" />
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
        </svg>
      </button>

      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-toggle"
        class="md:hidden p-2 rounded-md text-[#6B6B6B] dark:text-[#9B9B9B] hover:text-[#1A1A1A] dark:hover:text-[#F4F1EC] hover:bg-[#F2F0EC] dark:hover:bg-[#1C1C1F] transition-colors"
        aria-controls="mobile-menu"
        aria-expanded="false"
        aria-label="Toggle navigation menu"
      >
        <svg class="w-5 h-5" id="menu-icon-open" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M3 5a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zM3 10a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zM3 15a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1z" clip-rule="evenodd" />
        </svg>
        <svg class="w-5 h-5 hidden" id="menu-icon-close" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-[#F2F0EC] dark:border-[#1C1C1F]" role="navigation" aria-label="Mobile navigation">
    <ul class="px-4 py-2 space-y-1 list-none m-0">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              'block px-3 py-2 rounded-md text-sm font-medium transition-colors',
              currentPath.startsWith(href)
                ? 'text-[#2563EB] dark:text-[#3B82F6] bg-blue-50 dark:bg-blue-900/20'
                : 'text-[#6B6B6B] dark:text-[#9B9B9B] hover:text-[#1A1A1A] dark:hover:text-[#F4F1EC] hover:bg-[#F2F0EC] dark:hover:bg-[#1C1C1F]',
            ]}
            aria-current={currentPath.startsWith(href) ? 'page' : undefined}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  function syncToggleIcon() {
    const isDark = document.documentElement.classList.contains('dark');
    document.getElementById('theme-icon-moon')?.classList.toggle('hidden', isDark);
    document.getElementById('theme-icon-sun')?.classList.toggle('hidden', !isDark);
  }

  function setupHeader() {
    // Mobile menu
    const toggle = document.getElementById('mobile-menu-toggle');
    const menu = document.getElementById('mobile-menu');
    const iconOpen = document.getElementById('menu-icon-open');
    const iconClose = document.getElementById('menu-icon-close');

    toggle?.addEventListener('click', () => {
      const isOpen = menu?.classList.toggle('hidden') === false;
      toggle.setAttribute('aria-expanded', String(isOpen));
      iconOpen?.classList.toggle('hidden', isOpen);
      iconClose?.classList.toggle('hidden', !isOpen);
    });

    // Theme toggle
    syncToggleIcon();
    document.getElementById('theme-toggle')?.addEventListener('click', () => {
      const isDark = document.documentElement.classList.toggle('dark');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
      syncToggleIcon();
    });
  }

  document.addEventListener('astro:page-load', setupHeader);
</script>
