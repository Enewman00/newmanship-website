# Cloudflare Pages custom headers
# https://developers.cloudflare.com/pages/configuration/headers/

# HTML pages — revalidate on every request so deploys propagate immediately
/*
  Cache-Control: public, max-age=0, must-revalidate
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin

# Astro-generated hashed assets (JS bundles, CSS) — safe to cache forever
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Self-hosted fonts — content never changes at a given URL
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Favicons — cache for one week
/favicon.svg
  Cache-Control: public, max-age=604800

/apple-touch-icon.png
  Cache-Control: public, max-age=604800

# RSS feed — cache for 1 hour
/rss.xml
  Cache-Control: public, max-age=3600

# Sitemap — cache for 1 day
/sitemap-index.xml
  Cache-Control: public, max-age=86400

# robots.txt — cache for 1 day
/robots.txt
  Cache-Control: public, max-age=86400
